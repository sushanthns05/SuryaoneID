rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if the user is an admin
    // Assuming admin role is set on the custom claims or in a specific collection
    function isAdmin() {
      return isAuthenticated() && request.auth.token.admin == true;
    }

    // Helper function to verify user is accessing their own data
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Users Collection
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // Applications Collection
    match /applications/{applicationId} {
      // Anyone can create an application if authenticated
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      
      // Users can read their own applications
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      
      // Only admins can update applications (e.g. approve/reject)
      // Users can only update their application if it is in "Draft" status (for this demo, simplify to admin only)
      allow update: if isAdmin();
      
      // No one can delete applications
      allow delete: if false;
    }

    // Credentials Collection
    match /credentials/{credentialId} {
      // Only admins/cloud functions can write to credentials
      allow write: if isAdmin();
      // Credentials are public for verification purposes
      allow read: if true;
    }

    // Audit Logs Collection
    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }
  }
}
