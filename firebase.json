{

  "firestore": {
    "database": "oneidsurya",
    "rules": "firestore.rules"
  },
  "storage": {
    "rules": "storage.rules"
  },

  "hosting": {
    "site": "oneid-surya",
    "public": "out",
    "cleanUrls": true,
    "trailingSlash": false,
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ]
  }
}
